# Environment Variables — Cloud-Based Office Administration System
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# Local:   mongodb://localhost:27017/office_admin_db
# Atlas:   mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/office_admin_db
MONGO_URI=mongodb://localhost:27017/office_admin_db

# Client URL (React frontend)
CLIENT_URL=http://localhost:3000

# Future — JWT Authentication (Week 3+)
# JWT_SECRET=your_super_secret_key_here
# JWT_EXPIRE=7d

# Future — Cloud Storage (Week 4+)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
